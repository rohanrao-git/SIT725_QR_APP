{
  "info": {
    "_postman_id": "a1b2c3d4-sit725-qr-app-e2e",
    "name": "SIT725 QR App API (E2E)",
    "description": "Collection aligned with current backend routes. Use with npm run seed:e2e.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "adminEmail", "value": "admin@system.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "ownerEmail", "value": "owner@example.com" },
    { "key": "ownerPassword", "value": "owner123" },
    { "key": "pendingOwnerEmail", "value": "pending.owner@example.com" },
    { "key": "pendingOwnerPassword", "value": "owner123" },
    { "key": "newOwnerEmail", "value": "new.owner@example.com" },
    { "key": "adminToken", "value": "" },
    { "key": "ownerToken", "value": "" },
    { "key": "pendingOwnerId", "value": "" },
    { "key": "restaurantId", "value": "" },
    { "key": "menuItemId", "value": "" }
  ],
  "item": [
    {
      "name": "1) Public",
      "item": [
        {
          "name": "GET /",
          "request": { "method": "GET", "url": "{{baseUrl}}/" },
          "response": []
        },
        {
          "name": "POST /api/auth/register (new pending owner)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Owner\",\n  \"email\": \"{{newOwnerEmail}}\",\n  \"password\": \"owner123\",\n  \"pendingRestaurantName\": \"New Owner Bistro\",\n  \"pendingRestaurantAddress\": \"1 New Street\",\n  \"pendingRestaurantPhone\": \"+61 499 100 100\",\n  \"pendingRestaurantEmail\": \"new.owner.bistro@example.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST /api/auth/login (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('adminToken', json.token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /api/auth/login (approved owner)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('ownerToken', json.token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /api/auth/login (pending owner - expect 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{pendingOwnerEmail}}\",\n  \"password\": \"{{pendingOwnerPassword}}\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2) Admin",
      "item": [
        {
          "name": "GET /api/admin/owners/pending",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/owners/pending"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const owners = json.owners || [];",
                  "  const pending = owners.find(o => o.email === pm.collectionVariables.get('pendingOwnerEmail'));",
                  "  if (pending && pending._id) pm.collectionVariables.set('pendingOwnerId', pending._id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "PATCH /api/admin/owners/:id/approve",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/admin/owners/{{pendingOwnerId}}/approve"
          },
          "response": []
        },
        {
          "name": "GET /api/admin/restaurants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/restaurants"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const restaurants = json.restaurants || [];",
                  "  const r = restaurants[0];",
                  "  if (r && r._id) pm.collectionVariables.set('restaurantId', r._id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /api/admin/restaurants/:id/tables",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/admin/restaurants/{{restaurantId}}/tables",
            "body": { "mode": "raw", "raw": "{\n  \"totalTables\": 6\n}" }
          },
          "response": []
        },
        {
          "name": "GET /api/admin/restaurants/:id/tables",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/restaurants/{{restaurantId}}/tables"
          },
          "response": []
        },
        {
          "name": "GET /api/menu/:restaurantId (admin view)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/menu/{{restaurantId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3) Owner Scoped",
      "item": [
        {
          "name": "GET /api/menu/my",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": "{{baseUrl}}/api/menu/my"
          },
          "response": []
        },
        {
          "name": "GET /api/menu/my/tables",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": "{{baseUrl}}/api/menu/my/tables"
          },
          "response": []
        },
        {
          "name": "POST /api/menu/my (create menu item)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/menu/my",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grilled Salmon\",\n  \"category\": \"Mains\",\n  \"description\": \"Fresh Atlantic salmon with lemon butter sauce\",\n  \"price\": 28.5,\n  \"image\": \"\",\n  \"isAvailable\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.item && json.item._id) pm.collectionVariables.set('menuItemId', json.item._id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "PUT /api/menu/my/:itemId (update menu item)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/menu/my/{{menuItemId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 30.0,\n  \"description\": \"Fresh Atlantic salmon with lemon butter sauce and seasonal vegetables\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "PATCH /api/menu/my/:itemId/availability (toggle availability)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/menu/my/{{menuItemId}}/availability",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": false\n}"
            }
          },
          "response": []
        },
        {
          "name": "DELETE /api/menu/my/:itemId (delete menu item)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": "{{baseUrl}}/api/menu/my/{{menuItemId}}"
          },
          "response": []
        }
      ]
    }
  ]
}
